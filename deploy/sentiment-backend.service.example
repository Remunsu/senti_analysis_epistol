[Unit]
Description=Sentiment Analysis Django backend
After=network.target postgresql.service

[Service]
User=www-data
Group=www-data
WorkingDirectory=/opt/sentiment-app/backend
EnvironmentFile=/opt/sentiment-app/backend/.env
ExecStart=/opt/sentiment-app/backend/venv/bin/gunicorn config.wsgi:application --bind 127.0.0.1:8000 --workers 3 --timeout 300
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
